{
  "productName": "CryptoMafia",
  "version": "0.1.0",
  "identifier": "com.cryptomafia.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "beforeDevCommand": "cd ../frontend && npm run dev",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "CryptoMafia",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "minSdkVersion": 24,
      "compileSdkVersion": 34,
      "targetSdkVersion": 34,
      "aaptOptions": {
        "additionalParameters": ["--package-name", "com.cryptomafia.app"]
      },
      "packageName": "com.cryptomafia.app",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.VIBRATE"
      ]
    }
  },
  "plugins": {}
}
